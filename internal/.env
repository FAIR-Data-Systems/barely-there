ENCRYPTION_KEY_HEX=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef   # 64 hex chars = 32 bytes (generate with: openssl rand -hex 32)
RESULT_FORMAT=csv
QUERY_DIR=/queries
EXTERNAL_URL=http://localhost:3000   
TRIPLESTORE_URL=http://localhost:7200/repositories/fixme-sextans-fix
TRIPLESTORE_USER = markw
TRIPLESTORE_PASS = markw
POLL_INTERVAL=10 # seconds
# these set the permissions on the ./queries folder so that you can edit it 
UID=1000   #  at terminal:   id -u
GID=1000   # at terminal:  id -g